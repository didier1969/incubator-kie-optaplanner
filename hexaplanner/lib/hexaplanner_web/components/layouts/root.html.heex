<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-950">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={Phoenix.Controller.get_csrf_token()} />
    <title>Nexus - CFF/SBB Digital Twin</title>
    
    <!-- CSS Dependencies (Local) -->
    <link phx-track-static rel="stylesheet" href="/css/maplibre-gl.css" />
    
    <!-- Local JS Dependencies -->
    <script phx-track-static src="/js/vendor/tailwind.min.js"></script>
    <script phx-track-static src="/js/vendor/pmtiles.js"></script>
    <script phx-track-static src="/js/vendor/maplibre-gl.js"></script>
    <script phx-track-static src="/js/vendor/deck.gl.min.js"></script>
    <script phx-track-static src="/js/vendor/phoenix.min.js"></script>
    <script phx-track-static src="/js/vendor/phoenix_live_view.min.js"></script>
    
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              slate: { 950: '#020617', 900: '#0f172a', 800: '#1e293b' },
              amber: { 500: '#f59e0b' }
            }
          }
        }
      }
    </script>
    
    <!-- Custom Application Logic -->
    <script defer phx-track-static type="text/javascript" src="/js/app.js"></script>
  </head>
  <body class="text-white antialiased h-full font-mono overflow-hidden">
    <%= @inner_content %>
  </body>
</html>
